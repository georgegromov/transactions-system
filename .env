# Environment
ENV=local

TRANSACTION_PROCESSOR_PORT=8081
OUTBOX_PROCESSOR_PORT=8082
INBOX_PROCESSOR_PORT=8083
BALANCE_VIEWER_PORT=8084
AUTH_SERVICE_PORT=8085

# TRANSACTION HTTP Server
TRANSACTION_HTTP_PORT=8081
TRANSACTION_HTTP_READ_TIMEOUT=10s
TRANSACTION_HTTP_WRITE_TIMEOUT=10s
TRANSACTION_HTTP_IDLE_TIMEOUT=60s
TRANSACTION_HTTP_MAX_HEADER_BYTES=1024

# OUTBOX HTTP Server
OUTBOX_HTTP_PORT=8082
OUTBOX_HTTP_READ_TIMEOUT=10s
OUTBOX_HTTP_WRITE_TIMEOUT=10s
OUTBOX_HTTP_IDLE_TIMEOUT=60s
OUTBOX_HTTP_MAX_HEADER_BYTES=1024

# INBOX HTTP Server
INBOX_HTTP_PORT=8083
INBOX_HTTP_READ_TIMEOUT=10s
INBOX_HTTP_WRITE_TIMEOUT=10s
INBOX_HTTP_IDLE_TIMEOUT=60s
INBOX_HTTP_MAX_HEADER_BYTES=1024

# BALANCE VIEWER HTTP Server
BALANCE_VIEWER_HTTP_PORT=8084
BALANCE_VIEWER_HTTP_READ_TIMEOUT=10s
BALANCE_VIEWER_HTTP_WRITE_TIMEOUT=10s
BALANCE_VIEWER_HTTP_IDLE_TIMEOUT=60s
BALANCE_VIEWER_HTTP_MAX_HEADER_BYTES=1024

# Transactions Database
TRANSACTIONS_DB_POSTGRES_HOST=transactions-db
TRANSACTIONS_DB_POSTGRES_PORT=5432
TRANSACTIONS_DB_POSTGRES_USER=postgres
TRANSACTIONS_DB_POSTGRES_PASSWORD=postgres
TRANSACTIONS_DB_POSTGRES_DB=transactions

# Balances Database
BALANCES_DB_POSTGRES_HOST=balances-db
BALANCES_DB_POSTGRES_PORT=5432
BALANCES_DB_POSTGRES_USER=postgres
BALANCES_DB_POSTGRES_PASSWORD=postgres
BALANCES_DB_POSTGRES_DB=balances

# Zookeeper
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# Kafka
KAFKA_PORT=9092
KAFKA_BROKERS=kafka:29092
KAFKA_BROKER_ID=1
KAFKA_GROUP_ID=inbox-processor
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:29092,PLAINTEXT_HOST://0.0.0.0:9092
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Kafka UI
KAFKA_UI_PORT=3000
KAFKA_UI_CLUSTERS_0_NAME=transactions-system-kafka
KAFKA_UI_CLUSTERS_0_BOOTSTRAPSERVERS=kafka:29092

# Consul
CONSUL_PORT=8500